# La Quesería — environment template.
# Copy to `.env` and replace EVERY value below with real secrets. Never commit
# `.env`. These are non-functional placeholders only.
#
# Docker Compose auto-loads the sibling `.env` for ${VAR} interpolation.

# --- Postgres (compose `db` service) ---
POSTGRES_USER=replace-with-db-user
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=replace-with-db-name

# --- App ---
# AUTH_SECRET must be >= 32 chars. Generate one with:
#   openssl rand -base64 48
AUTH_SECRET=replace-with-a-32-plus-character-secret

# Canonical public URL — drives SEO metadata, sitemap and robots.
# Production MUST be the real domain (deploy.sh rejects localhost/127.0.0.1).
# For local dev you may set this to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=replace-with-production-url

# Host port the web container publishes (container always listens on 3000).
WEB_PORT=3000

# --- Admin bootstrap (only read when seeding / --bootstrap-admin) ---
# No committed defaults. Supply real values here; deploy rejects placeholders.
ADMIN_EMAIL=replace-with-admin-email@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# --- Local-only (NOT used by compose; there DATABASE_URL is derived from POSTGRES_*) ---
# DATABASE_URL=postgresql://replace-with-db-user:replace-with-a-strong-db-password@localhost:5432/replace-with-db-name
